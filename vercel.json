{
  "buildCommand": "npm install --legacy-peer-deps && react-scripts build",
  "outputDirectory": "build",
  "rewrites": [
    { 
      "source": "/api/(.*)", 
      "destination": "/api/$1" 
    },
    { 
      "source": "/((?!api/).*)", 
      "destination": "/index.html" 
    }
  ],
  "crons": [
    {
      "path": "/api/updateQuote",
      "schedule": "0 1 * * *"
    }
  ]
}
